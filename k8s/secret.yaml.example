apiVersion: v1
kind: Secret
metadata:
  name: oxmux-secret
  namespace: oxmux
  labels:
    app.kubernetes.io/name: oxmux
type: Opaque
# All values must be base64-encoded: echo -n "value" | base64
stringData:
  OXMUX_JWT_SECRET: "REPLACE_WITH_JWT_SECRET"
  COTURN_AUTH_SECRET: "REPLACE_WITH_COTURN_AUTH_SECRET_FROM_K8S_CLUSTER_MULTI"
  DATABASE_URL: "sqlite:/data/oxmux.db"
  # Optional: override with Postgres
  # DATABASE_URL: "postgres://oxmux:PASSWORD@postgres-svc:5432/oxmux"
